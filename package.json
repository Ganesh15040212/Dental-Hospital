{
  "name": "ai-dental-receptionist",
  "version": "1.0.0",
  "description": "AI Dental Receptionist Webhook using Express, Google Calendar, and ElevenLabs",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev:backend": "node --watch index.js",
    "dev:frontend": "npm run dev --prefix client",
    "dev:admin": "npm run dev --prefix admin",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^140.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
